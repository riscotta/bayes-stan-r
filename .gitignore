# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# ------------------------------------------------------------
# Pastas do repositório (artefatos regeneráveis)
#
# - outputs/: artefatos gerados pelos scripts (PDF, tabelas, modelos, etc.)
# - data/interim e data/processed: dados derivados (não versionar)
#
# Mantemos apenas os .gitkeep para preservar a estrutura.
# ------------------------------------------------------------

outputs/**
!outputs/**/
!outputs/**/.gitkeep

data/interim/**
!data/interim/**/
!data/interim/**/.gitkeep

data/processed/**
!data/processed/**/
!data/processed/**/.gitkeep

# Se alguém extrair manualmente o ZIP do ISUS/SIA, evite commitar sem querer.
data/raw/isus_sia/ISUS_SIA_PARS.csv

# Dataset público (ESL) que pode ser baixado pelo script; evitar commit acidental.
data/raw/SAheart.data

# Patch files (ad-hoc diffs)
*.patch

# Quarto / relatórios gerados
reports/_site/


# Cache local dos microdados oficiais do Censo Escolar (arquivos grandes)
data/raw/censo_escolar/**
!data/raw/censo_escolar/
!data/raw/censo_escolar/.gitkeep

# PNAD Contínua — os CSVs deste estudo estão versionados no repositório.
# Mantemos apenas a possibilidade de ignorar artefatos auxiliares temporários.
data/raw/pnadc_desocupacao/*.tmp
data/raw/pnadc_desocupacao/*.bak

# PMS / Serviços — o CSV deste estudo está versionado no repositório.
# Mantemos apenas a possibilidade de ignorar artefatos auxiliares temporários.
data/raw/pms_servicos/*.tmp
data/raw/pms_servicos/*.bak

# Retratacoes cientificas — base externa do Kaggle (nao versionar CSV bruto)
data/raw/retractions_time_to_retraction/*.csv

# Consumer Shopping Trends — base externa do Kaggle (nao versionar CSV bruto)
data/raw/consumer_shopping_trends/**/*.csv

